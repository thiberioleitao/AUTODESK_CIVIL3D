<Window x:Class="ZagoCivil3D.Views.AdicionarLabelsProfileViewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Adicionar Labels aos Profile Views"
        Width="920"
        Height="560"
        MinWidth="920"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F5F5">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <TextBlock Text="ADICIONAR LABELS AOS PROFILE VIEWS"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FF2D2D2D" />
                <TextBlock Text="Para cada alinhamento do desenho, percorre seus profile views e aplica um Profile Line Label Style aos profiles cujo nome contem o texto do filtro."
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#FF6A6A6A"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="22,18,22,18">
                <Border Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Estilo do Label"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Profile Line Label Style" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="LabelStyleComboBox" Grid.Row="0" Grid.Column="2" Height="36" Padding="8,4" FontSize="14"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Profile Line Label Style" FontWeight="Bold" /><LineBreak />
                                    Estilo de label aplicado em cada combinacao (profile view x profile filtrado). Digite para filtrar a lista de estilos disponiveis.
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Margin="0,14,0,0"
                        Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Filtro de Profiles"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Nome do profile contem" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="FiltroNomeTextBox" Grid.Row="0" Grid.Column="2" Height="36" Padding="8,6" FontSize="14" VerticalContentAlignment="Center">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Filtro por nome do profile" FontWeight="Bold" /><LineBreak />
                                    Apenas os profiles cujo nome contem este texto (case-insensitive) recebem labels. Ex.: "TER" aplica somente nos perfis de terreno natural. Deixe vazio para incluir todos os profiles.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border x:Name="StatusBorder"
                Grid.Row="2"
                Visibility="Collapsed"
                BorderThickness="1"
                CornerRadius="0"
                Padding="22,10">
            <TextBlock x:Name="StatusTextBlock"
                       FontSize="13"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Text="O comando aplica labels em todos os profile views do desenho."
                           FontSize="13"
                           Foreground="#FF666666" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="CancelarButton" Width="110" Height="36" Margin="0,0,10,0" Click="AoClicarCancelar" Content="Fechar" />
                    <Button x:Name="ConfirmarButton" Width="130" Height="36" Click="AoClicarConfirmar" Content="Executar" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
