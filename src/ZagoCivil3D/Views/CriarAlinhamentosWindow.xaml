<Window x:Class="ZagoCivil3D.Views.CriarAlinhamentosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Criar Alinhamentos"
        Width="860"
        Height="560"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F5F5">
	<Grid Margin="0">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
			<StackPanel>
				<TextBlock Text="1.0 - CRIAR ALINHAMENTOS A PARTIR DE POLILINHAS"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FF2D2D2D" />
				<TextBlock Text="Defina os parametros iniciais da interface para continuar com o processamento na camada de servico."
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#FF6A6A6A"
                           TextWrapping="Wrap" />
			</StackPanel>
		</Border>

		<ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
			<StackPanel Margin="22,18,22,18">
				<Border Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
					<TextBlock Text="Inputs"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
				</Border>

				<Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="260" />
							<ColumnDefinition Width="18" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="Layer"
                                   FontSize="14"
                                   Foreground="#FF444444" />
						<ComboBox x:Name="LayerComboBox"
                                  Grid.Row="0"
                                  Grid.Column="2"
                                  Height="36"
                                  Margin="0,0,0,14"
                                  Padding="8,4"
                                  FontSize="14"
                                  ItemsSource="{Binding Layers}"
                                  SelectedItem="{Binding LayerSelecionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                     <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="Style"
                                   FontSize="14"
                                   Foreground="#FF444444" />
						<ComboBox x:Name="StyleComboBox"
                                  Grid.Row="1"
                                  Grid.Column="2"
                                  Height="36"
                                  Margin="0,0,0,14"
                                  Padding="8,4"
                                  FontSize="14"
                                  ItemsSource="{Binding Styles}"
                                  SelectedItem="{Binding StyleSelecionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                     <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="LabelSet"
                                   FontSize="14"
                                   Foreground="#FF444444" />
						<ComboBox x:Name="LabelSetComboBox"
                                  Grid.Row="2"
                                  Grid.Column="2"
                                  Height="36"
                                  Margin="0,0,0,14"
                                  Padding="8,4"
                                  FontSize="14"
                                  ItemsSource="{Binding LabelSets}"
                                  SelectedItem="{Binding LabelSetSelecionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                     <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="Prefixo"
                                   FontSize="14"
                                   Foreground="#FF444444" />
						<TextBox x:Name="PrefixoTextBox"
                                 Grid.Row="3"
                                 Grid.Column="2"
                                 Height="36"
                                 Margin="0,0,0,14"
                                 Padding="8,4"
                                 FontSize="14"
                                 Text="{Binding Prefixo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                     <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="Zona (texto)"
                                   FontSize="14"
                                   Foreground="#FF444444" />
                        <TextBox x:Name="ZonaTextBox"
                                 Grid.Row="4"
                                 Grid.Column="2"
                                 Height="36"
                                 Margin="0,0,0,14"
                                 Padding="8,4"
                                 FontSize="14"
                                 Text="{Binding ZonaTexto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                     <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="Numero inicial"
                                   FontSize="14"
                                   Foreground="#FF444444" />
						<TextBox x:Name="NumeroInicialTextBox"
                                 Grid.Row="5"
                                 Grid.Column="2"
                                 Height="36"
                                 Margin="0,0,0,14"
                                 Padding="8,4"
                                 FontSize="14"
                                 Text="{Binding NumeroInicialTexto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="6"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="Incremento"
                                   FontSize="14"
                                   Foreground="#FF444444" />
						<TextBox x:Name="IncrementoTextBox"
                                 Grid.Row="6"
                                 Grid.Column="2"
                                 Height="36"
                                 Padding="8,4"
                                 FontSize="14"
                                 Text="{Binding IncrementoTexto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
					</Grid>
				</Border>

				<Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
					<CheckBox x:Name="ApagarPolilinhasCheckBox"
                              IsChecked="{Binding ApagarPolilinhas, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Content="Apagar polilinhas apos a confirmacao da tela"
                              FontSize="14"
                              Foreground="#FF444444" />
				</Border>
			</StackPanel>
		</ScrollViewer>

		<Border Grid.Row="2"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,1,0,0"
                Padding="22,14">
			<DockPanel LastChildFill="False">
				<TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Text="A confirmacao apenas devolve os valores preenchidos para a camada de comando."
                           FontSize="13"
                           Foreground="#FF666666" />
				<StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
					<Button x:Name="CancelarButton"
                            Width="110"
                            Height="36"
                            Margin="0,0,10,0"
                            Click="AoClicarCancelar"
                            Content="Cancelar" />
					<Button x:Name="ConfirmarButton"
                            Width="130"
                            Height="36"
                            Click="AoClicarConfirmar"
                            Content="Confirmar" />
				</StackPanel>
			</DockPanel>
		</Border>
	</Grid>
</Window>
