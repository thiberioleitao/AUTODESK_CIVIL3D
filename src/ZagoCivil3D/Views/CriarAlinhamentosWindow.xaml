<Window x:Class="ZagoCivil3D.Views.CriarAlinhamentosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Criar Alinhamentos — Por Polilinha"
        Width="880"
        Height="540"
        MinWidth="880"
        MinHeight="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F5F5"
        ToolTipService.InitialShowDelay="250"
        ToolTipService.ShowDuration="20000">
    <Window.Resources>
        <Style TargetType="ToolTip">
            <Setter Property="MaxWidth" Value="360" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="CRIAR ALINHAMENTOS A PARTIR DE POLILINHAS"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#FF2D2D2D" />
                    <Border Background="#FFEAF3FF"
                            BorderBrush="#FF0078D4"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10,2"
                            Margin="12,4,0,0"
                            VerticalAlignment="Center"
                            Cursor="Help">
                        <Border.ToolTip>
                            <TextBlock TextWrapping="Wrap">
                                <Run Text="Como a rotina funciona:" FontWeight="Bold" />
                                <LineBreak />
                                <Run Text="Cria alignments a partir de todas as polilinhas de um layer, sem ordenacao especifica." />
                                <LineBreak />
                                <LineBreak />
                                <Run Text="A numeracao segue sequencialmente (incremento de 1) a partir do numero inicial definido." FontStyle="Italic" />
                            </TextBlock>
                        </Border.ToolTip>
                        <TextBlock Text="i  Como funciona"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#FF0078D4" />
                    </Border>
                </StackPanel>
                <TextBlock Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#FF6A6A6A"
                           TextWrapping="Wrap"
                           Text="Cria alignments para todas as polilinhas encontradas no layer selecionado, com numeracao sequencial." />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="22,18,22,18">
                <Border Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Inputs"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="Layer"
                                   FontSize="14"
                                   Foreground="#FF444444" />
                        <ComboBox x:Name="LayerComboBox"
                                  Grid.Row="0"
                                  Grid.Column="2"
                                  Height="36"
                                  Margin="0,0,0,14"
                                  Padding="8,4"
                                  FontSize="14"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True"
                                  ToolTip="Layer contendo as polilinhas que serao convertidas em alignments. Pode digitar para filtrar." />

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="Style"
                                   FontSize="14"
                                   Foreground="#FF444444" />
                        <ComboBox x:Name="StyleComboBox"
                                  Grid.Row="1"
                                  Grid.Column="2"
                                  Height="36"
                                  Margin="0,0,0,14"
                                  Padding="8,4"
                                  FontSize="14"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True"
                                  ToolTip="Estilo visual aplicado aos alignments criados (define como sao desenhados: cores, espessura, estacoes etc.). Pode digitar para filtrar." />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="LabelSet"
                                   FontSize="14"
                                   Foreground="#FF444444" />
                        <ComboBox x:Name="LabelSetComboBox"
                                  Grid.Row="2"
                                  Grid.Column="2"
                                  Height="36"
                                  Margin="0,0,0,14"
                                  Padding="8,4"
                                  FontSize="14"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True"
                                  ToolTip="Conjunto de rotulos (label set) associado aos alignments: define quais labels sao criados automaticamente (estacoes, tangentes, curvas etc.). Pode digitar para filtrar." />

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="Prefixo"
                                   FontSize="14"
                                   Foreground="#FF444444" />
                        <TextBox x:Name="PrefixoTextBox"
                                 Grid.Row="3"
                                 Grid.Column="2"
                                 Height="36"
                                 Margin="0,0,0,14"
                                 Padding="8,4"
                                 FontSize="14"
                                 ToolTip="Prefixo usado na nomenclatura dos alignments. Ex.: 'D' gera D01, D02, D03, ... com preenchimento automatico de zero a esquerda para dois digitos." />

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="Numero inicial"
                                   FontSize="14"
                                   Foreground="#FF444444" />
                        <TextBox x:Name="NumeroInicialTextBox"
                                 Grid.Row="4"
                                 Grid.Column="2"
                                 Height="36"
                                 Padding="8,4"
                                 FontSize="14"
                                 ToolTip="Numero do primeiro alignment. Deve ser maior que zero. A numeracao segue sequencialmente (incremento de 1)." />
                    </Grid>
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <CheckBox x:Name="ApagarPolilinhasCheckBox"
                              Content="Apagar polilinhas originais apos a criacao dos alignments"
                              FontSize="14"
                              Foreground="#FF444444"
                              ToolTip="Se marcado, as polilinhas do layer serao removidas do desenho apos a criacao bem-sucedida dos alignments correspondentes. Deixe desmarcado para preservar as polilinhas originais." />
                </Border>

                <Border x:Name="StatusBorder"
                        Margin="0,14,0,0"
                        Background="#FFF7F7F7"
                        BorderBrush="#FFDDDDDD"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="14,10"
                        Visibility="Collapsed">
                    <TextBlock x:Name="StatusTextBlock"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Foreground="#FF444444" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#FF666666"
                           TextWrapping="Wrap"
                           MaxWidth="520">
                    <Run Text="A janela e modeless:" FontWeight="SemiBold" />
                    <Run Text="voce pode interagir com o Civil 3D (zoom, pan, selecao) sem fechar este painel." />
                </TextBlock>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button x:Name="CancelarButton"
                            Width="110"
                            Height="36"
                            Margin="0,0,10,0"
                            Click="AoClicarCancelar"
                            Content="Fechar"
                            ToolTip="Fecha esta janela sem executar nada." />
                    <Button x:Name="ConfirmarButton"
                            Width="150"
                            Height="36"
                            Click="AoClicarConfirmar"
                            Content="Criar Alignments"
                            ToolTip="Executa a criacao dos alignments a partir das polilinhas do layer selecionado." />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
