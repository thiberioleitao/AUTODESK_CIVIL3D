<Window x:Class="ZagoCivil3D.Views.CriarCorredoresAlinhamentosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Criar Corredores a Partir de Alinhamentos"
        Width="920"
        Height="620"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F5F5">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <TextBlock Text="CRIAR CORREDORES A PARTIR DE ALINHAMENTOS"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FF2D2D2D" />
                <TextBlock Text="Cria um corredor vazio para cada alinhamento do desenho, com nome derivado do proprio alinhamento. Prefixo e sufixo sao opcionais."
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#FF6A6A6A"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="22,18,22,18">
                <Border Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Nome do corredor"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Prefixo (opcional)" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="PrefixoTextBox" Grid.Row="0" Grid.Column="2" Height="36" Padding="8,6" FontSize="14" VerticalContentAlignment="Center">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Prefixo do nome do corredor" FontWeight="Bold" /><LineBreak />
                                    Texto adicionado ao inicio do nome do corredor. Ex.: prefixo "CORR_" + alinhamento "EIXO-01" gera corredor "CORR_EIXO-01". Deixe vazio para usar apenas o nome do alinhamento.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,9,0,0" Text="Sufixo (opcional)" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="SufixoTextBox" Grid.Row="2" Grid.Column="2" Height="36" Padding="8,6" FontSize="14" VerticalContentAlignment="Center">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Sufixo do nome do corredor" FontWeight="Bold" /><LineBreak />
                                    Texto adicionado ao final do nome do corredor. Ex.: alinhamento "EIXO-01" + sufixo "_CORR" gera corredor "EIXO-01_CORR". Deixe vazio para usar apenas o nome do alinhamento.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,9,0,0" Text="Exemplo (primeiro alinhamento)" FontSize="14" Foreground="#FF888888" />
                        <TextBlock x:Name="ExemploTextBlock" Grid.Row="4" Grid.Column="2" Margin="0,11,0,0" FontSize="13" FontStyle="Italic" Foreground="#FF888888" Text="(preenchido apos digitar)" />
                    </Grid>
                </Border>

                <Border Margin="0,14,0,0"
                        Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Opcoes"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <StackPanel>
                        <CheckBox x:Name="IgnorarExistentesCheckBox"
                                  FontSize="14"
                                  Foreground="#FF444444"
                                  IsChecked="True"
                                  Content="Ignorar alinhamentos cujo corredor ja existe">
                            <CheckBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Ignorar corredores existentes" FontWeight="Bold" /><LineBreak />
                                    Quando marcado, se ja houver um corredor com o nome final calculado, o alinhamento e ignorado silenciosamente. Quando desmarcado, a colisao e reportada como erro e o corredor nao e criado.
                                </TextBlock>
                            </CheckBox.ToolTip>
                        </CheckBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border x:Name="StatusBorder"
                Grid.Row="2"
                Visibility="Collapsed"
                BorderThickness="1"
                CornerRadius="0"
                Padding="22,10">
            <TextBlock x:Name="StatusTextBlock"
                       FontSize="13"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Text="O comando cria um corredor vazio por alinhamento no desenho."
                           FontSize="13"
                           Foreground="#FF666666" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="CancelarButton" Width="110" Height="36" Margin="0,0,10,0" Click="AoClicarCancelar" Content="Fechar" />
                    <Button x:Name="ConfirmarButton" Width="130" Height="36" Click="AoClicarConfirmar" Content="Executar" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
