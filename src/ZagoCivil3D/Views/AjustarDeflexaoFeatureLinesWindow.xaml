<Window x:Class="ZagoCivil3D.Views.AjustarDeflexaoFeatureLinesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ajustar Deflexao - Feature Lines"
        Width="1100"
        Height="960"
        MinWidth="1100"
        MinHeight="960"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F5F5">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <TextBlock Text="AJUSTAR DEFLEXAO DE FEATURE LINES"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FF2D2D2D" />
                <TextBlock Text="Ajuste iterativo de deflexao em feature lines. Percorre os PI points de cada feature line em passadas alternadas (montante-jusante e jusante-montante), ajustando as cotas das estacoes ate que a deflexao entre segmentos adjacentes fique dentro do limite informado."
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#FF6A6A6A"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1"
                    x:Name="MainTabControl"
                    Margin="18,10,18,0"
                    Background="Transparent"
                    BorderBrush="#FFD9D9D9">
            <TabItem Header="Parametros" FontSize="13">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="4,14,4,14">
                <Border Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Selecao de feature lines"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Site (opcional)" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="SiteComboBox" Grid.Row="0" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Site das feature lines" FontWeight="Bold" /><LineBreak />
                                    Selecione o site de onde as feature lines serao lidas. Deixe em branco para processar as feature lines de todos os sites do desenho. Digite para filtrar a lista.
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,9,0,0" Text="Filtro por nome (opcional)" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="FiltroNomeTextBox" Grid.Row="1" Grid.Column="2" Height="36" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Filtro por nome" FontWeight="Bold" /><LineBreak />
                                    Substring case-insensitive aplicada ao nome da feature line. Exemplo: "ESTACA 3908" processa apenas as feature lines cujo nome contem esse texto. Deixe em branco para processar todas.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>
                    </Grid>
                </Border>

                <Border Margin="0,14,0,0"
                        Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Parametros do ajuste"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Deflexao limite" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="DeflexaoLimiteTextBox" Grid.Row="0" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                    <Run Text="Deflexao limite (adimensional)" FontWeight="Bold" /><LineBreak />
                                    Criterio absoluto de aceitacao da diferenca entre as grades adjacentes (Gi - Gi+1). Quando |deflexao| &lt;= limite, o ponto e considerado OK. Valor padrao 0.0129, alinhado com a rotina Dynamo original.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,9,0,0" Text="Passo minimo / precisao (m)" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="PassoTextBox" Grid.Row="1" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                    <Run Text="Passo minimo do ajuste dinamico" FontWeight="Bold" /><LineBreak />
                                    Piso do passo incremental aplicado ao Z. O engine parte deste passo e o aumenta enquanto faz progresso, reduzindo-o pela metade quando detecta overshoot (bisseccao). Na pratica atua como a precisao minima do ajuste. Padrao 0.01 m.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,9,0,0" Text="Passo maximo dinamico (m)" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="PassoMaximoTextBox" Grid.Row="2" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                    <Run Text="Teto do passo dinamico" FontWeight="Bold" /><LineBreak />
                                    Limite superior do passo auto-ajustado. Evita saltos muito grandes em uma unica iteracao. Valores maiores aceleram a convergencia quando a deflexao inicial e grande; valores menores dao mais robustez em feature lines com segmentos curtos. Padrao 0.50 m.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,9,0,0" Text="Indice maximo de PI (por FL)" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="IndiceMaximoTextBox" Grid.Row="3" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="380">
                                    <Run Text="Indice maximo de PI por feature line" FontWeight="Bold" /><LineBreak />
                                    Limite aplicado <Run FontStyle="Italic" Text="dentro de cada feature line" />, nao no total do desenho. Cada FL e processada independentemente, avaliando os PIs de indice 1 ate min(valor informado, n-2), onde n e o numero de PIs dessa FL.<LineBreak /><LineBreak />
                                    Exemplo: 1000 FLs com 15 PIs cada e IndiceMaximo=1000 processa todos os PIs internos (1 a 13) de cada uma das 1000 FLs.<LineBreak /><LineBreak />
                                    Use valores baixos apenas quando quiser restringir o ajuste a um trecho inicial de cada FL. Padrao 1000 (sem limite efetivo em FLs tipicas).
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,9,0,0" Text="Numero de passadas" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="PassadasTextBox" Grid.Row="4" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                    <Run Text="Numero de passadas globais" FontWeight="Bold" /><LineBreak />
                                    Quantas varreduras completas serao feitas em cada feature line. Passadas impares vao montante->jusante, pares vao jusante->montante. Padrao 2 (ida e volta).
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>

                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,9,0,0" Text="Limite de iteracoes por ponto" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="IteracoesPorPontoTextBox" Grid.Row="5" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                    <Run Text="Numero maximo de iteracoes internas por PI" FontWeight="Bold" /><LineBreak />
                                    Protege contra loops infinitos no iterador dinamico de cada ponto. Valores baixos (50-200) aceleram em casos ruins mas podem deixar violacoes sem convergir. Valores altos (1000+) garantem convergencia em casos dificeis. Padrao 200.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>

                        <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,9,0,0" Text="Estrategia de ajuste" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="ModoComboBox" Grid.Row="6" Grid.Column="2" Height="36" Padding="8,4" FontSize="14">
                            <ComboBoxItem Content="Multi-ponto (avalia Zi-1, Zi, Zi+1 por volume)" Tag="MultiPonto" IsSelected="True" />
                            <ComboBoxItem Content="Ponto central (ajusta apenas Zi)" Tag="PontoCentral" />
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="380">
                                    <Run Text="Estrategia de escolha do PI a ajustar" FontWeight="Bold" /><LineBreak />
                                    <Run Text="Multi-ponto:" FontWeight="Bold" /> em cada violacao compara o custo volumetrico de mover Zi-1, Zi ou Zi+1, aplicando bonus de reutilizacao para estacoes ja alteradas. Tende a menor volume de corte/aterro e a concentrar alteracoes em menos estacoes distintas.<LineBreak /><LineBreak />
                                    <Run Text="Ponto central:" FontWeight="Bold" /> ajusta sempre o PI central (i) do trio. Estrategia conservadora: a perturbacao fica restrita ao proprio ponto violador, sem propagar elevacao a vizinhos.
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>

                        <CheckBox x:Name="CriarMarcadoresCheckBox" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,14,0,0"
                                  IsChecked="True" FontSize="14" Foreground="#FF444444"
                                  Content="Criar marcadores visuais no desenho (circulos + multileaders)">
                            <CheckBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="400">
                                    <Run Text="Marcadores visuais" FontWeight="Bold" /><LineBreak />
                                    Quando marcado, apos a execucao o comando desenha:<LineBreak />
                                    - <Run FontWeight="Bold" Foreground="#FF2B7B2B" Text="Circulo verde + multileader" /> em cada PI ajustado com sucesso<LineBreak />
                                    - <Run FontWeight="Bold" Foreground="#FFB22222" Text="Circulo vermelho + multileader" /> em cada PI em violacao remanescente ou falha geometrica<LineBreak />
                                    - <Run FontWeight="Bold" Foreground="#FF1A5FB4" Text="Apenas circulo azul" /> nos PIs inalterados (ja estavam dentro do limite)<LineBreak /><LineBreak />
                                    Cada status vai para sua propria layer, permitindo controlar a visibilidade via gerenciador de layers. Os marcadores sao identificados por XData e removidos automaticamente na proxima execucao, sem afetar outras entidades na mesma layer.
                                </TextBlock>
                            </CheckBox.ToolTip>
                        </CheckBox>

                        <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,9,0,0" Text="Layer - ajustado (verde)" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="LayerAjustadoComboBox" Grid.Row="8" Grid.Column="2" Height="36" Margin="0,0,0,10" Padding="8,4" FontSize="14"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="380">
                                    <Run Text="Layer dos PIs ajustados com sucesso" FontWeight="Bold" /><LineBreak />
                                    Layer onde sao colocados os circulos e multileaders verdes (PIs que violavam e foram corrigidos). Se vazio, usa <Run FontStyle="Italic" Text="ZAGO_DEFLEXAO_AJUSTADO" />. Se a layer nao existir, e criada automaticamente.
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>

                        <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,9,0,0" Text="Layer - falha (vermelho)" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="LayerFalhaComboBox" Grid.Row="9" Grid.Column="2" Height="36" Margin="0,0,0,10" Padding="8,4" FontSize="14"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="380">
                                    <Run Text="Layer dos PIs em violacao remanescente ou falha" FontWeight="Bold" /><LineBreak />
                                    Layer onde sao colocados os circulos e multileaders vermelhos (PIs que nao foram corrigidos ou falharam geometricamente). Se vazio, usa <Run FontStyle="Italic" Text="ZAGO_DEFLEXAO_FALHA" />.
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>

                        <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,9,0,0" Text="Layer - inalterado (azul)" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="LayerInalteradoComboBox" Grid.Row="10" Grid.Column="2" Height="36" Margin="0,0,0,10" Padding="8,4" FontSize="14"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="380">
                                    <Run Text="Layer dos PIs inalterados" FontWeight="Bold" /><LineBreak />
                                    Layer onde sao colocados os circulos azuis dos PIs que ja estavam dentro do limite antes do ajuste. Estes PIs recebem apenas o circulo (sem multileader), para evitar poluicao visual em feature lines extensas. Se vazio, usa <Run FontStyle="Italic" Text="ZAGO_DEFLEXAO_INALTERADO" />.
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>

                        <TextBlock Grid.Row="11" Grid.Column="0" Margin="0,9,0,0" Text="Altura do texto (m)" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="TamanhoMarcadorTextBox" Grid.Row="11" Grid.Column="2" Height="36" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="380">
                                    <Run Text="Altura do texto do multileader" FontWeight="Bold" /><LineBreak />
                                    Altura do texto, em unidades do desenho. A seta do multileader e o raio do circulo tambem sao escalados proporcionalmente (raio do circulo = 2x altura do texto). Ajuste conforme a escala do desenho. Padrao 1.0 m.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
            </TabItem>

            <TabItem Header="Resultados" x:Name="TabResultados" IsEnabled="False" FontSize="13">
                <Grid Margin="4,10,4,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Cabecalho agregado -->
                    <Border Grid.Row="0"
                            Background="White"
                            BorderBrush="#FFE1E1E1"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14,10">
                        <StackPanel>
                            <TextBlock x:Name="ResumoAgregadoTextBlock"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#FF2D2D2D"
                                       Text="Resumo agregado" />
                            <TextBlock x:Name="ResumoAgregadoDetalheTextBlock"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#FF6A6A6A"
                                       TextWrapping="Wrap"
                                       Text="Execute o comando para ver os resultados." />
                        </StackPanel>
                    </Border>

                    <!-- Legenda visual -->
                    <Border Grid.Row="1"
                            Margin="0,8,0,0"
                            Background="White"
                            BorderBrush="#FFE1E1E1"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,6">
                        <WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                <Rectangle Width="14" Height="14" Fill="#FFEEF7EE" Stroke="#FF4C9A4C" StrokeThickness="1" />
                                <TextBlock Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center" Text="OK / ajustado" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                <Rectangle Width="14" Height="14" Fill="#FFFFF8E1" Stroke="#FFB38A00" StrokeThickness="1" />
                                <TextBlock Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center" Text="Fronteira (depende de FLs vizinhas)" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                <Rectangle Width="14" Height="14" Fill="#FFFDECEC" Stroke="#FFA71D2A" StrokeThickness="1" />
                                <TextBlock Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center" Text="Violacao interna remanescente" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="14" Height="14" Fill="#FFFAD4D4" Stroke="#FF822828" StrokeThickness="1" />
                                <TextBlock Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center" Text="Erro / falha geometrica" />
                            </StackPanel>
                        </WrapPanel>
                    </Border>

                    <!-- Resumo por Feature Line -->
                    <TextBlock Grid.Row="2" Margin="0,14,0,6"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#FF444444"
                               Text="Resumo por Feature Line" />
                    <DataGrid Grid.Row="3"
                              x:Name="GridResumoFL"
                              MaxHeight="160"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              FontSize="12"
                              AlternatingRowBackground="#FFF8F8F8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header=" " Binding="{Binding Icone}" Width="26" />
                            <DataGridTextColumn Header="Feature Line" Binding="{Binding Nome}" Width="180" />
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusTexto}" Width="160" />
                            <DataGridTextColumn Header="PIs" Binding="{Binding TotalPIAvaliados}" Width="45" />
                            <DataGridTextColumn Header="Viol. inicio" Binding="{Binding ViolacoesIniciais}" Width="75" />
                            <DataGridTextColumn Header="Viol. final" Binding="{Binding ViolacoesFinais}" Width="70" />
                            <DataGridTextColumn Header="Internas" Binding="{Binding ViolacoesFinaisInternas}" Width="65" />
                            <DataGridTextColumn Header="Fronteira" Binding="{Binding ViolacoesFinaisFronteira}" Width="70" />
                            <DataGridTextColumn Header="Estacoes" Binding="{Binding EstacoesAlteradas}" Width="70" />
                            <DataGridTextColumn Header="|dZ| max" Binding="{Binding DeltaZMaximo, StringFormat={}{0:F3} m}" Width="75" />
                            <DataGridTextColumn Header="|dZ| medio" Binding="{Binding DeltaZMedio, StringFormat={}{0:F3} m}" Width="85" />
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="SemViolacoes">
                                        <Setter Property="Background" Value="#FFF4F9F4" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="AjustadoComSucesso">
                                        <Setter Property="Background" Value="#FFEEF7EE" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="ViolacoesApenasEmFronteira">
                                        <Setter Property="Background" Value="#FFFFF8E1" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="ViolacoesInternasRemanescentes">
                                        <Setter Property="Background" Value="#FFFDECEC" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Erro">
                                        <Setter Property="Background" Value="#FFFAD4D4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>

                    <!-- Detalhes por PI -->
                    <Grid Grid.Row="4" Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,6" LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FF444444"
                                       VerticalAlignment="Center"
                                       Text="Detalhes por PI" />
                            <CheckBox x:Name="FiltrarSoViolacoesCheckBox"
                                      DockPanel.Dock="Right"
                                      VerticalAlignment="Center"
                                      FontSize="12"
                                      Foreground="#FF555555"
                                      Content="Mostrar apenas violacoes finais"
                                      Checked="AoMudarFiltroDetalhes"
                                      Unchecked="AoMudarFiltroDetalhes" />
                        </DockPanel>

                        <Border Grid.Row="1" Height="1" Background="#FFE1E1E1" />

                        <DataGrid Grid.Row="2"
                                  x:Name="GridDetalhesPI"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  FontSize="12"
                                  AlternatingRowBackground="#FFF8F8F8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header=" " Binding="{Binding Icone}" Width="26" />
                                <DataGridTextColumn Header="Feature Line" Binding="{Binding NomeFeatureLine}" Width="180" />
                                <DataGridTextColumn Header="PI" Binding="{Binding IndicePI}" Width="45" />
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusTexto}" Width="140" />
                                <DataGridTextColumn Header="Defl. inicial" Binding="{Binding DeflexaoInicial, StringFormat={}{0:F4}}" Width="85" />
                                <DataGridTextColumn Header="Defl. final" Binding="{Binding DeflexaoFinal, StringFormat={}{0:F4}}" Width="85" />
                                <DataGridTextColumn Header="|dZ| aplicado" Binding="{Binding DeltaZAcumulado, StringFormat={}{0:F3} m}" Width="95" />
                                <DataGridTextColumn Header="Vezes alvo" Binding="{Binding VezesAlvo}" Width="75" />
                                <DataGridTextColumn Header="Iteracoes" Binding="{Binding IteracoesAcumuladas}" Width="75" />
                                <DataGridTextColumn Header="Resolvido via" Binding="{Binding ResolvidoVia}" Width="160" />
                                <DataGridTextColumn Header="Fronteira" Binding="{Binding EhFronteiraInterna}" Width="70" />
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="JaDentroDoLimite">
                                            <Setter Property="Background" Value="#FFF4F9F4" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="AjustadoComSucesso">
                                            <Setter Property="Background" Value="#FFEEF7EE" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="ViolacaoRemanescente">
                                            <Setter Property="Background" Value="#FFFDECEC" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="FalhaGeometrica">
                                            <Setter Property="Background" Value="#FFFAD4D4" />
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Status}" Value="ViolacaoRemanescente" />
                                                <Condition Binding="{Binding EhFronteiraInterna}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#FFFFF8E1" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Border x:Name="StatusBorder"
                Grid.Row="2"
                Visibility="Collapsed"
                BorderThickness="1"
                CornerRadius="0"
                Padding="22,10">
            <TextBlock x:Name="StatusTextBlock"
                       FontSize="13"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Text="O comando altera as cotas dos PI points das feature lines selecionadas."
                           FontSize="13"
                           Foreground="#FF666666" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="CancelarButton" Width="110" Height="36" Margin="0,0,10,0" Click="AoClicarCancelar" Content="Fechar" />
                    <Button x:Name="ConfirmarButton" Width="130" Height="36" Click="AoClicarConfirmar" Content="Executar" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
