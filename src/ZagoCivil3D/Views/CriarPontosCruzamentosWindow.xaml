<Window x:Class="ZagoCivil3D.Views.CriarPontosCruzamentosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Criar Pontos nos Cruzamentos entre Alinhamentos"
        Width="960"
        Height="760"
        MinWidth="960"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F5F5">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <TextBlock Text="CRIAR PONTOS NOS CRUZAMENTOS ENTRE ALINHAMENTOS"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FF2D2D2D" />
                <TextBlock Text="Calcula os cruzamentos (interseccoes no plano XY) entre todos os alinhamentos do desenho e cria CogoPoints nos pontos unicos. A numeracao e gerada em blocos de comprimento L (trackers), agrupados por colunas e ordenados de norte para sul."
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#FF6A6A6A"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="22,18,22,18">
                <Border Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Geometria do bloco (tracker)"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Comprimento do tracker (m)" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="ComprimentoTrackerTextBox" Grid.Row="0" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                    <Run Text="Comprimento L do tracker" FontWeight="Bold" /><LineBreak />
                                    Altura vertical do bloco em unidades do desenho. Cada bloco contem os pontos com Y entre o topo e topo menos L. Padrao 140 m.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,9,0,0" Text="Pontos por coluna (esperado)" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="PontosPorTrackerTextBox" Grid.Row="1" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                    <Run Text="Pontos esperados por coluna" FontWeight="Bold" /><LineBreak />
                                    Quantidade de pontos esperada em cada coluna do bloco. Colunas com contagem diferente geram apenas avisos — os pontos sao criados do mesmo jeito. Padrao 15.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>

                        <CheckBox x:Name="AlternarLadoInicialCheckBox" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,4,0,0"
                                  IsChecked="False" FontSize="14" Foreground="#FF444444"
                                  Content="Alternar lado inicial entre blocos (serpentear)">
                            <CheckBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                    <Run Text="Alternar lado inicial" FontWeight="Bold" /><LineBreak />
                                    Quando marcado, os blocos impares comecam pela coluna mais a oeste e os pares pela mais a leste, de modo que a numeracao serpenteia entre blocos consecutivos. Quando desmarcado, todos os blocos comecam pela coluna oeste.
                                </TextBlock>
                            </CheckBox.ToolTip>
                        </CheckBox>
                    </Grid>
                </Border>

                <Border Margin="0,14,0,0"
                        Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Rotulo e destino dos CogoPoints"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Prefixo do rotulo" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="PrefixoTextBox" Grid.Row="0" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                    <Run Text="Prefixo do rotulo sequencial" FontWeight="Bold" /><LineBreak />
                                    Texto colocado antes do numero sequencial. Ex.: prefixo "P" gera "P01", "P02", ..., "P99", "P100".
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,9,0,0" Text="Descricao inicial (fallback)" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="DescricaoTextBox" Grid.Row="1" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                    <Run Text="Descricao inicial" FontWeight="Bold" /><LineBreak />
                                    Descricao bruta usada no momento da criacao. Em seguida, a RawDescription e substituida pelo rotulo ordenado (ex.: P01). O valor inicial so persiste se algum ponto, por falha, nao receber o rotulo final.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,9,0,0" Text="Layer dos CogoPoints" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="LayerComboBox" Grid.Row="2" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                    <Run Text="Layer dos CogoPoints" FontWeight="Bold" /><LineBreak />
                                    Layer aplicada aos CogoPoints criados. Se a layer nao existir no desenho, ela e criada automaticamente. Digite para filtrar a lista. Se vazio, a layer corrente e usada.
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>

                        <CheckBox x:Name="CriarCogoPointsCheckBox" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,4,0,0"
                                  IsChecked="True" FontSize="14" Foreground="#FF444444"
                                  Content="Criar CogoPoints no desenho (desmarcar apenas para dry-run)">
                            <CheckBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                    <Run Text="Criar CogoPoints" FontWeight="Bold" /><LineBreak />
                                    Quando desmarcado, o comando apenas calcula os cruzamentos e a ordenacao, sem alterar o desenho. Util para validar os parametros antes de criar os pontos de fato.
                                </TextBlock>
                            </CheckBox.ToolTip>
                        </CheckBox>
                    </Grid>
                </Border>

                <Border Margin="0,14,0,0"
                        Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Tolerancias (avancado)"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Tolerancia XY - duplicados (m)" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="ToleranciaDuplicadosTextBox" Grid.Row="0" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="380">
                                    <Run Text="Tolerancia para deteccao de duplicados" FontWeight="Bold" /><LineBreak />
                                    Dois cruzamentos com distancia XY menor ou igual a este valor sao considerados o mesmo ponto e colapsados. Padrao 0.01 m.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,9,0,0" Text="Tolerancia X - coluna (m)" FontSize="14" Foreground="#FF444444" />
                        <TextBox x:Name="ToleranciaColunaTextBox" Grid.Row="1" Grid.Column="2" Height="36" Padding="8,4" FontSize="14">
                            <TextBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="380">
                                    <Run Text="Tolerancia para agrupamento em colunas" FontWeight="Bold" /><LineBreak />
                                    Pontos com X dentro dessa faixa em relacao ao X de referencia sao agrupados na mesma coluna. Padrao 0.10 m.
                                </TextBlock>
                            </TextBox.ToolTip>
                        </TextBox>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border x:Name="StatusBorder"
                Grid.Row="2"
                Visibility="Collapsed"
                BorderThickness="1"
                CornerRadius="0"
                Padding="22,10">
            <TextBlock x:Name="StatusTextBlock"
                       FontSize="13"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Text="O comando cria CogoPoints em todos os cruzamentos entre os alinhamentos do desenho."
                           FontSize="13"
                           Foreground="#FF666666" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="CancelarButton" Width="110" Height="36" Margin="0,0,10,0" Click="AoClicarCancelar" Content="Fechar" />
                    <Button x:Name="ConfirmarButton" Width="130" Height="36" Click="AoClicarConfirmar" Content="Executar" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
