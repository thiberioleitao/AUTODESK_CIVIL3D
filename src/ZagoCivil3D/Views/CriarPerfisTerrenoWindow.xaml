<Window x:Class="ZagoCivil3D.Views.CriarPerfisTerrenoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Criar Perfis do Terreno (TN / Terraplenagem)"
        Width="920"
        Height="640"
        MinWidth="920"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F5F5">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <TextBlock Text="CRIAR PERFIS DO TERRENO NATURAL E TERRAPLENAGEM"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FF2D2D2D" />
                <TextBlock Text="Cria surface profiles para todos os alinhamentos do desenho, amostrando as cotas de uma superficie TIN (terreno natural ou terraplenagem). Replica a rotina Dynamo 1.1."
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#FF6A6A6A"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="22,18,22,18">
                <Border Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Selecao"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Superficie" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="SuperficieComboBox" Grid.Row="0" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Superficie TIN" FontWeight="Bold" /><LineBreak />
                                    Superficie utilizada para amostrar as cotas do terreno ao longo de cada alinhamento. Pode ser a superficie do terreno natural (TN) ou a de terraplenagem, dependendo do tipo de perfil desejado.
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,9,0,0" Text="Estilo de perfil" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="EstiloPerfilComboBox" Grid.Row="1" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Estilo de perfil" FontWeight="Bold" /><LineBreak />
                                    Estilo visual aplicado aos surface profiles criados (cor, tipo de linha, etc.).
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,9,0,0" Text="Conjunto de rotulos" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="ConjuntoRotulosComboBox" Grid.Row="2" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Conjunto de rotulos" FontWeight="Bold" /><LineBreak />
                                    Conjunto de rotulos (labels) exibidos ao longo do perfil, como estacoes e cotas.
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,9,0,0" Text="Layer de destino" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="CamadaComboBox" Grid.Row="3" Grid.Column="2" Height="36" Padding="8,4" FontSize="14"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Layer de destino" FontWeight="Bold" /><LineBreak />
                                    Layer onde os surface profiles serao criados.
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Margin="0,14,0,0"
                        Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Opcoes"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Nome do perfil"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#FF444444" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="#FF6A6A6A"
                                   TextWrapping="Wrap"
                                   Text="Os perfis criados usam o padrao &quot;{NomeSuperficie}-{NomeAlinhamento}&quot;. Exemplo: superficie &quot;1.Prim.+Terrap.&quot; + alinhamento &quot;D01-01&quot; gera o perfil &quot;1.Prim.+Terrap.-D01-01&quot;." />

                        <CheckBox x:Name="SubstituirPerfisCheckBox"
                                  Margin="0,14,0,0"
                                  FontSize="14"
                                  Foreground="#FF444444"
                                  Content="Substituir perfis existentes com o mesmo nome">
                            <CheckBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Substituir perfis existentes" FontWeight="Bold" /><LineBreak />
                                    Quando marcado, perfis que ja existem com o mesmo nome serao apagados e recriados. Quando desmarcado, alinhamentos que ja possuem o perfil serao ignorados.
                                </TextBlock>
                            </CheckBox.ToolTip>
                        </CheckBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border x:Name="StatusBorder"
                Grid.Row="2"
                Visibility="Collapsed"
                BorderThickness="1"
                CornerRadius="0"
                Padding="22,10">
            <TextBlock x:Name="StatusTextBlock"
                       FontSize="13"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Text="O comando cria surface profiles para todos os alinhamentos do desenho."
                           FontSize="13"
                           Foreground="#FF666666" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="CancelarButton" Width="110" Height="36" Margin="0,0,10,0" Click="AoClicarCancelar" Content="Fechar" />
                    <Button x:Name="ConfirmarButton" Width="130" Height="36" Click="AoClicarConfirmar" Content="Executar" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
