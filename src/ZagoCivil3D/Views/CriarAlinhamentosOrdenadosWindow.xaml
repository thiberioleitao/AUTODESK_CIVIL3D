<Window x:Class="ZagoCivil3D.Views.CriarAlinhamentosOrdenadosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Criar Alinhamentos — Ordenado N→S (Horizontal) e O→L (Vertical)"
        Width="880"
        Height="640"
        MinWidth="880"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F5F5"
        ToolTipService.InitialShowDelay="250"
        ToolTipService.ShowDuration="20000">
    <Window.Resources>
        <Style TargetType="ToolTip">
            <Setter Property="MaxWidth" Value="360" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="CRIAR ALINHAMENTOS ORDENADOS"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#FF2D2D2D" />
                    <Border Background="#FFEAF3FF"
                            BorderBrush="#FF0078D4"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10,2"
                            Margin="12,4,0,0"
                            VerticalAlignment="Center"
                            Cursor="Help">
                        <Border.ToolTip>
                            <TextBlock TextWrapping="Wrap">
                                <Run Text="Como a rotina funciona:" FontWeight="Bold" />
                                <LineBreak />
                                <Run Text="1º — São criados os alignments das polilinhas HORIZONTAIS (layer 1), ordenadas do Norte para o Sul (maior Y primeiro)." />
                                <LineBreak />
                                <Run Text="2º — Em seguida são criados os alignments das polilinhas VERTICAIS (layer 2), ordenadas do Oeste para o Leste (menor X primeiro)." />
                                <LineBreak />
                                <LineBreak />
                                <Run Text="A numeração é sequencial e compartilhada entre os dois grupos: as verticais continuam do último número usado pelas horizontais." FontStyle="Italic" />
                            </TextBlock>
                        </Border.ToolTip>
                        <TextBlock Text="ⓘ  Como funciona"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#FF0078D4" />
                    </Border>
                </StackPanel>
                <TextBlock x:Name="OrdemResumoTextBlock"
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#FF6A6A6A"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="22,18,22,18">
                <Border Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Ordem de processamento"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Escolha qual grupo de polilinhas é criado primeiro:"
                                   FontSize="13"
                                   Foreground="#FF555555"
                                   Margin="0,0,0,10" />
                        <RadioButton x:Name="OrdemHorizontaisPrimeiroRadio"
                                     GroupName="OrdemProcessamento"
                                     IsChecked="True"
                                     Margin="0,4,0,4"
                                     ToolTip="As horizontais (layer 1) são criadas primeiro, ordenadas de Norte para Sul. Em seguida as verticais (layer 2) continuam a numeração, ordenadas de Oeste para Leste.">
                            <TextBlock FontSize="13" Foreground="#FF333333">
                                <Run Text="1º Horizontais (N→S)  " FontWeight="SemiBold" Foreground="#FF0078D4" /><Run Text="→  2º Verticais (O→L)" />
                            </TextBlock>
                        </RadioButton>
                        <RadioButton x:Name="OrdemVerticaisPrimeiroRadio"
                                     GroupName="OrdemProcessamento"
                                     Margin="0,4,0,4"
                                     ToolTip="As verticais (layer 2) são criadas primeiro, ordenadas de Oeste para Leste. Em seguida as horizontais (layer 1) continuam a numeração, ordenadas de Norte para Sul.">
                            <TextBlock FontSize="13" Foreground="#FF333333">
                                <Run Text="1º Verticais (O→L)  " FontWeight="SemiBold" Foreground="#FF0078D4" /><Run Text="→  2º Horizontais (N→S)" />
                            </TextBlock>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <Border Margin="0,14,0,0"
                        Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Inputs"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   FontSize="14"
                                   Foreground="#FF444444">
                            <Run Text="①" FontWeight="Bold" Foreground="#FF0078D4" />
                            <Run Text=" Layer horizontais (L↔O)" />
                        </TextBlock>
                        <ComboBox x:Name="LayerHorizontaisComboBox"
                                  Grid.Row="0"
                                  Grid.Column="2"
                                  Height="36"
                                  Margin="0,0,0,14"
                                  Padding="8,4"
                                  FontSize="14"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap">
                                    <Run Text="Primeiro grupo a ser processado." FontWeight="Bold" />
                                    <LineBreak />
                                    Layer contendo as polilinhas orientadas no sentido Leste-Oeste (horizontais, paralelas entre si).
                                    <LineBreak />
                                    <LineBreak />
                                    Os alignments deste grupo serão criados primeiro, ordenados do NORTE para o SUL (maior Y para menor Y).
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   FontSize="14"
                                   Foreground="#FF444444">
                            <Run Text="②" FontWeight="Bold" Foreground="#FF0078D4" />
                            <Run Text=" Layer verticais (N↕S)" />
                        </TextBlock>
                        <ComboBox x:Name="LayerVerticaisComboBox"
                                  Grid.Row="1"
                                  Grid.Column="2"
                                  Height="36"
                                  Margin="0,0,0,14"
                                  Padding="8,4"
                                  FontSize="14"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap">
                                    <Run Text="Segundo grupo a ser processado." FontWeight="Bold" />
                                    <LineBreak />
                                    Layer contendo as polilinhas orientadas no sentido Norte-Sul (verticais, paralelas entre si).
                                    <LineBreak />
                                    <LineBreak />
                                    Os alignments deste grupo serão criados DEPOIS das horizontais, ordenados do OESTE para o LESTE (menor X para maior X). A numeração continua do último número usado pelas horizontais.
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="Style"
                                   FontSize="14"
                                   Foreground="#FF444444" />
                        <ComboBox x:Name="StyleComboBox"
                                  Grid.Row="2"
                                  Grid.Column="2"
                                  Height="36"
                                  Margin="0,0,0,14"
                                  Padding="8,4"
                                  FontSize="14"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True"
                                  ToolTip="Estilo visual aplicado aos alignments criados (define como são desenhados: cores, espessura, estações etc.). Pode digitar para filtrar." />

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="LabelSet"
                                   FontSize="14"
                                   Foreground="#FF444444" />
                        <ComboBox x:Name="LabelSetComboBox"
                                  Grid.Row="3"
                                  Grid.Column="2"
                                  Height="36"
                                  Margin="0,0,0,14"
                                  Padding="8,4"
                                  FontSize="14"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True"
                                  ToolTip="Conjunto de rótulos (label set) associado aos alignments: define quais labels são criados automaticamente (estações, tangentes, curvas etc.). Pode digitar para filtrar." />

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="Prefixo"
                                   FontSize="14"
                                   Foreground="#FF444444" />
                        <TextBox x:Name="PrefixoTextBox"
                                 Grid.Row="4"
                                 Grid.Column="2"
                                 Height="36"
                                 Margin="0,0,0,14"
                                 Padding="8,4"
                                 FontSize="14"
                                 ToolTip="Prefixo usado na nomenclatura dos alignments. Ex.: 'D' gera D01, D02, D03, ... com preenchimento automático de zero à esquerda para dois dígitos." />

                        <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Margin="0,9,0,0"
                                   Text="Numero inicial"
                                   FontSize="14"
                                   Foreground="#FF444444" />
                        <TextBox x:Name="NumeroInicialTextBox"
                                 Grid.Row="5"
                                 Grid.Column="2"
                                 Height="36"
                                 Padding="8,4"
                                 FontSize="14"
                                 ToolTip="Número do primeiro alignment. Deve ser maior que zero. A numeração segue sequencialmente (incremento de 1) e continua das horizontais para as verticais." />
                    </Grid>
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <CheckBox x:Name="ApagarPolilinhasCheckBox"
                              Content="Apagar polilinhas originais após a criação dos alignments"
                              FontSize="14"
                              Foreground="#FF444444"
                              ToolTip="Se marcado, as polilinhas dos dois layers serão removidas do desenho após a criação bem-sucedida dos alignments correspondentes. Deixe desmarcado para preservar as polilinhas originais." />
                </Border>

                <Border x:Name="StatusBorder"
                        Margin="0,14,0,0"
                        Background="#FFF7F7F7"
                        BorderBrush="#FFDDDDDD"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="14,10"
                        Visibility="Collapsed">
                    <TextBlock x:Name="StatusTextBlock"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Foreground="#FF444444" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#FF666666"
                           TextWrapping="Wrap"
                           MaxWidth="520">
                    <Run Text="A janela é modeless:" FontWeight="SemiBold" />
                    <Run Text="você pode interagir com o Civil 3D (zoom, pan, seleção) sem fechar este painel." />
                </TextBlock>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button x:Name="CancelarButton"
                            Width="110"
                            Height="36"
                            Margin="0,0,10,0"
                            Click="AoClicarCancelar"
                            Content="Fechar"
                            ToolTip="Fecha esta janela sem executar nada." />
                    <Button x:Name="ConfirmarButton"
                            Width="150"
                            Height="36"
                            Click="AoClicarConfirmar"
                            Content="Criar Alignments"
                            ToolTip="Executa a criação dos alignments na ordem definida: horizontais (N→S) primeiro, verticais (O→L) em seguida." />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
