<Window x:Class="ZagoCivil3D.Views.ExportarCsvBaciasSubbaciasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Exportar CSV de Bacias e Subbacias"
        Width="1080"
        Height="820"
        MinWidth="1080"
        MinHeight="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F5F5">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <TextBlock Text="EXPORTAR CSV DE BACIAS E SUBBACIAS"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FF2D2D2D" />
                <TextBlock Text="Varre as hatches das bacias, associa cada uma ao MText de ID e a polilinha de talvegue contidos, calcula area, comprimento, declividade e o ID da bacia de jusante a partir das regioes dos corredores. Gera CSV com verificacoes por linha."
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#FF6A6A6A"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <TabControl x:Name="AbasPrincipais"
                    Grid.Row="1"
                    Margin="18,14,18,0"
                    Background="Transparent"
                    BorderBrush="#FFD0D0D0">
            <TabItem Header="Configuracao" FontSize="14" Padding="16,6">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="#FFF5F5F5">
                    <StackPanel Margin="4,14,4,18">
                        <Border Background="#FFF0F0F0"
                                BorderBrush="#FFD8D8D8"
                                BorderThickness="1"
                                Padding="12,9">
                            <TextBlock Text="Arquivo de saida"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#FF555555" />
                        </Border>

                        <Border Margin="0,14,0,0"
                                Background="White"
                                BorderBrush="#FFE1E1E1"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Caminho do CSV" FontSize="14" Foreground="#FF444444" />
                                <TextBox x:Name="CaminhoCsvTextBox"
                                         Grid.Row="0" Grid.Column="2"
                                         Height="36" Padding="8,6" FontSize="14"
                                         VerticalContentAlignment="Center">
                                    <TextBox.ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                            <Run Text="Caminho do CSV" FontWeight="Bold" /><LineBreak />
                                            Caminho absoluto onde o arquivo sera gravado (sera sobrescrito). Use o botao "Selecionar..." para abrir o dialogo de salvamento. O arquivo e gerado em UTF-8 com BOM para abrir corretamente no Excel.
                                        </TextBlock>
                                    </TextBox.ToolTip>
                                </TextBox>
                                <Button x:Name="SelecionarCsvButton"
                                        Grid.Row="0" Grid.Column="4"
                                        Width="130" Height="36"
                                        Content="Selecionar..."
                                        Click="AoClicarSelecionarCsv" />
                            </Grid>
                        </Border>

                        <Border Margin="0,14,0,0"
                                Background="#FFF0F0F0"
                                BorderBrush="#FFD8D8D8"
                                BorderThickness="1"
                                Padding="12,9">
                            <TextBlock Text="Layers de entrada"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#FF555555" />
                        </Border>

                        <Border Margin="0,14,0,0"
                                Background="White"
                                BorderBrush="#FFE1E1E1"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Filtro das layers de hatches" FontSize="14" Foreground="#FF444444" />
                                <TextBox x:Name="PrefixoLayersHatchesTextBox"
                                         Grid.Row="0" Grid.Column="2"
                                         Height="36" Margin="0,0,0,14"
                                         Padding="8,6" FontSize="14"
                                         VerticalContentAlignment="Center">
                                    <TextBox.ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                            <Run Text="Filtro das layers das hatches" FontWeight="Bold" /><LineBreak />
                                            Todas as layers cujo nome contem este texto sao varridas em busca de hatches. Padrao Zago: "HDR-BACIA" (casa "HDR-BACIA 01", "HDR-BACIA 02", etc.).
                                        </TextBlock>
                                    </TextBox.ToolTip>
                                </TextBox>

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,9,0,0" Text="Prefixo a remover do nome (BACIA)" FontSize="14" Foreground="#FF444444" />
                                <TextBox x:Name="PrefixoRemoverBaciaTextBox"
                                         Grid.Row="1" Grid.Column="2"
                                         Height="36" Margin="0,0,0,14"
                                         Padding="8,6" FontSize="14"
                                         VerticalContentAlignment="Center">
                                    <TextBox.ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                            <Run Text="Prefixo removido para formar BACIA" FontWeight="Bold" /><LineBreak />
                                            Removido do inicio do nome da layer para compor o valor da coluna BACIA, com title case aplicado. Ex.: layer "HDR-BACIA 01" com prefixo "HDR-" gera "Bacia 01". Deixe vazio para usar o nome completo da layer.
                                        </TextBlock>
                                    </TextBox.ToolTip>
                                </TextBox>

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,9,0,0" Text="Layer dos MTexts (IDs das subbacias)" FontSize="14" Foreground="#FF444444" />
                                <ComboBox x:Name="LayerMTextsComboBox"
                                          Grid.Row="2" Grid.Column="2"
                                          Height="36" Margin="0,0,0,14"
                                          Padding="8,4" FontSize="14"
                                          IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                                    <ComboBox.ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                            <Run Text="Layer dos MTexts das subbacias" FontWeight="Bold" /><LineBreak />
                                            Layer onde estao os MText/DBText com os IDs das subbacias (ex.: "SB-01", "SB-02"). Apenas textos cujo conteudo contem o prefixo abaixo sao considerados. Padrao Zago: "A - TEXT BACIA".
                                        </TextBlock>
                                    </ComboBox.ToolTip>
                                </ComboBox>

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,9,0,0" Text="Prefixo do texto da subbacia" FontSize="14" Foreground="#FF444444" />
                                <TextBox x:Name="PrefixoTextoSubbaciaTextBox"
                                         Grid.Row="3" Grid.Column="2"
                                         Height="36" Margin="0,0,0,14"
                                         Padding="8,6" FontSize="14"
                                         VerticalContentAlignment="Center">
                                    <TextBox.ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                            <Run Text="Filtro do conteudo do MText" FontWeight="Bold" /><LineBreak />
                                            Apenas MTexts cujo conteudo contem este texto (case-insensitive) sao aceitos como ID de subbacia. Padrao Zago: "SB". Deixe vazio para aceitar qualquer texto.
                                        </TextBlock>
                                    </TextBox.ToolTip>
                                </TextBox>

                                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,9,0,0" Text="Layer dos talvegues" FontSize="14" Foreground="#FF444444" />
                                <ComboBox x:Name="LayerTalveguesComboBox"
                                          Grid.Row="4" Grid.Column="2"
                                          Height="36" Padding="8,4" FontSize="14"
                                          IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                                    <ComboBox.ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                            <Run Text="Layer dos talvegues" FontWeight="Bold" /><LineBreak />
                                            Layer onde estao as polilinhas de talvegue. Para cada hatch o comando procura a polilinha cujos dois extremos estao dentro do contorno — essa fornece L_TALVEGUE e S_TALVEGUE. Padrao Zago: "HDR - TALVEGUES SUBBACIAS".
                                        </TextBlock>
                                    </ComboBox.ToolTip>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border Margin="0,14,0,0"
                                Background="#FFF0F0F0"
                                BorderBrush="#FFD8D8D8"
                                BorderThickness="1"
                                Padding="12,9">
                            <TextBlock Text="Superficie e jusante"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#FF555555" />
                        </Border>

                        <Border Margin="0,14,0,0"
                                Background="White"
                                BorderBrush="#FFE1E1E1"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Superficie TIN (para S_TALVEGUE)" FontSize="14" Foreground="#FF444444" />
                                <ComboBox x:Name="SuperficieComboBox"
                                          Grid.Row="0" Grid.Column="2"
                                          Height="36" Margin="0,0,0,14"
                                          Padding="8,4" FontSize="14"
                                          IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                                    <ComboBox.ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                            <Run Text="Superficie TIN" FontWeight="Bold" /><LineBreak />
                                            Usada para calcular S_TALVEGUE = (z_montante - z_jusante) / L. Se deixar em branco, a coluna S_TALVEGUE fica vazia no CSV. Digite para filtrar as superficies do desenho.
                                        </TextBlock>
                                    </ComboBox.ToolTip>
                                </ComboBox>

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,9,0,0" Text="Raio de busca do jusante (m)" FontSize="14" Foreground="#FF444444" />
                                <TextBox x:Name="RaioJusanteTextBox"
                                         Grid.Row="1" Grid.Column="2"
                                         Height="36" Padding="8,6" FontSize="14"
                                         VerticalContentAlignment="Center">
                                    <TextBox.ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="360">
                                            <Run Text="Raio de busca" FontWeight="Bold" /><LineBreak />
                                            Distancia maxima (em metros do desenho) entre o ponto final do talvegue e o eixo de uma baseline region para que a regiao seja considerada como ID_JUSANTE. Padrao: 10.
                                        </TextBlock>
                                    </TextBox.ToolTip>
                                </TextBox>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="AbaResultadosItem" Header="Resultados" FontSize="14" Padding="16,6">
                <Grid Background="#FFF5F5F5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="4,14,4,0"
                            Background="White"
                            BorderBrush="#FFE1E1E1"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14,10">
                        <StackPanel>
                            <TextBlock x:Name="ResumoResultadosTextBlock"
                                       FontSize="13"
                                       Foreground="#FF444444"
                                       Text="Clique em Exportar para gerar o CSV e ver os resultados aqui." />
                            <TextBlock x:Name="ArquivoGeradoTextBlock"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#FF888888"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="Collapsed" />
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="LinhasDataGrid"
                              Grid.Row="1"
                              Margin="4,12,4,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              RowHeaderWidth="0"
                              FontSize="12"
                              Background="White"
                              AlternatingRowBackground="#FFFAFAFA"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TemAviso}" Value="True">
                                        <Setter Property="Background" Value="#FFFFF4E5" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="BACIA" Binding="{Binding Bacia}" Width="70" />
                            <DataGridTextColumn Header="SUBBACIA" Binding="{Binding Subbacia}" Width="90" />
                            <DataGridTextColumn Header="AREA" Binding="{Binding Area, StringFormat=N2}" Width="90" />
                            <DataGridTextColumn Header="L_TALVEGUE" Binding="{Binding Comprimento, StringFormat=N2}" Width="100" />
                            <DataGridTextColumn Header="S_TALVEGUE" Binding="{Binding Declividade, StringFormat=N6}" Width="110" />
                            <DataGridTextColumn Header="ID_JUSANTE" Binding="{Binding IdJusante}" Width="100" />
                            <DataGridTextColumn Header="VERF_SB" Binding="{Binding VerfSb}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="ToolTip" Value="{Binding VerfSb}" />
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="OK">
                                                <Setter Property="Foreground" Value="#FF2E7D32" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="VERF_A" Binding="{Binding VerfA}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="ToolTip" Value="{Binding VerfA}" />
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="OK">
                                                <Setter Property="Foreground" Value="#FF2E7D32" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="VERF_L" Binding="{Binding VerfL}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="ToolTip" Value="{Binding VerfL}" />
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="OK">
                                                <Setter Property="Foreground" Value="#FF2E7D32" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="VERF_S" Binding="{Binding VerfS}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="ToolTip" Value="{Binding VerfS}" />
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="OK">
                                                <Setter Property="Foreground" Value="#FF2E7D32" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border x:Name="AvisosBorder"
                            Grid.Row="2"
                            Margin="4,12,4,14"
                            MaxHeight="200"
                            Background="#FFFFF4E5"
                            BorderBrush="#FFE5A23E"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12,10"
                            Visibility="Collapsed">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top"
                                       x:Name="AvisosCabecalhoTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FF8A5A00"
                                       Text="Avisos (REVISAR)" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Margin="0,6,0,0">
                                <ItemsControl x:Name="AvisosItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Titulo}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FF6A4400" />
                                                <ItemsControl ItemsSource="{Binding Mensagens}" Margin="12,2,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}"
                                                                       FontSize="12"
                                                                       Foreground="#FF5E4200"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,1,0,1" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border x:Name="StatusBorder"
                Grid.Row="2"
                Visibility="Collapsed"
                BorderThickness="1"
                CornerRadius="0"
                Padding="22,10">
            <TextBlock x:Name="StatusTextBlock"
                       FontSize="13"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Text="O CSV e gravado em UTF-8 com BOM, separador virgula."
                           FontSize="13"
                           Foreground="#FF666666" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="CancelarButton" Width="110" Height="36" Margin="0,0,10,0" Click="AoClicarCancelar" Content="Fechar" />
                    <Button x:Name="ConfirmarButton" Width="130" Height="36" Click="AoClicarConfirmar" Content="Exportar" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
