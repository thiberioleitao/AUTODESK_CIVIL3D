<Window x:Class="ZagoCivil3D.Views.TerraplenagemFeatureLinesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Terraplenagem - Feature Lines Separadas"
        Width="920"
        Height="760"
        MinWidth="920"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F5F5">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <TextBlock Text="1.0 - TERRAPLENAGEM FEATURE LINES SEPARADAS"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FF2D2D2D" />
                <TextBlock Text="Replica em C# o fluxo do Dynamo: filtra feature lines por poligono, ajusta deflexao e executa a etapa iterativa de comparacao com a superficie."
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#FF6A6A6A"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="22,18,22,18">
                <Border Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Inputs"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Site" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="SiteComboBox" Grid.Row="0" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,9,0,0" Text="Layer do poligono de filtro" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="LayerComboBox" Grid.Row="1" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,9,0,0" Text="Superficie base" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="SurfaceComboBox" Grid.Row="2" Grid.Column="2" Height="36" Padding="8,4" FontSize="14" />
                    </Grid>
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Ajuste de deflexao" FontSize="15" FontWeight="SemiBold" Foreground="#FF444444" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Deflexao limite" FontSize="14" Foreground="#FF444444" />
                            <TextBox x:Name="DeflexaoLimiteTextBox" Grid.Row="0" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,9,0,0" Text="Numero maximo de pontos por FL" FontSize="14" Foreground="#FF444444" />
                            <TextBox x:Name="NumeroMaximoPontosTextBox" Grid.Row="1" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,9,0,0" Text="Passo incremental do ajuste de cota" FontSize="14" Foreground="#FF444444" />
                            <TextBox x:Name="PassoIncrementalTextBox" Grid.Row="2" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,9,0,0" Text="Quantidade de passadas globais" FontSize="14" Foreground="#FF444444" />
                            <TextBox x:Name="QuantidadePassadasTextBox" Grid.Row="3" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,9,0,0" Text="Percentual objetivo" FontSize="14" Foreground="#FF444444" />
                            <TextBox x:Name="PercentualObjetivoTextBox" Grid.Row="4" Grid.Column="2" Height="36" Padding="8,4" FontSize="14" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Ajuste por superficie" FontSize="15" FontWeight="SemiBold" Foreground="#FF444444" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Numero de tentativas por ponto" FontSize="14" Foreground="#FF444444" />
                            <TextBox x:Name="NumeroTentativasTextBox" Grid.Row="0" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,9,0,0" Text="Tolerancia baixa da superficie" FontSize="14" Foreground="#FF444444" />
                            <TextBox x:Name="ToleranciaBaixaTextBox" Grid.Row="1" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,9,0,0" Text="Tolerancia alta da superficie" FontSize="14" Foreground="#FF444444" />
                            <TextBox x:Name="ToleranciaAltaTextBox" Grid.Row="2" Grid.Column="2" Height="36" Margin="0,0,0,14" Padding="8,4" FontSize="14" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,9,0,0" Text="Maximo de ajustes por feature line" FontSize="14" Foreground="#FF444444" />
                            <TextBox x:Name="MaximoAjustesTextBox" Grid.Row="3" Grid.Column="2" Height="36" Padding="8,4" FontSize="14" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Text="O comando executa o processamento diretamente nas feature lines do desenho atual."
                           FontSize="13"
                           Foreground="#FF666666" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="CancelarButton" Width="110" Height="36" Margin="0,0,10,0" Click="AoClicarCancelar" Content="Cancelar" />
                    <Button x:Name="ConfirmarButton" Width="130" Height="36" Click="AoClicarConfirmar" Content="Executar" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
