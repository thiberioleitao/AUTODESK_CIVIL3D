<Window x:Class="ZagoCivil3D.Views.MudarLabelSetAlinhamentosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Mudar Label Set dos Alinhamentos"
        Width="920"
        Height="560"
        MinWidth="920"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F5F5">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <TextBlock Text="MUDAR LABEL SET DOS ALINHAMENTOS"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FF2D2D2D" />
                <TextBlock Text="Aplica um Alignment Label Set Style a todos os alinhamentos do desenho. Opcionalmente apaga os labels existentes antes de importar o novo conjunto."
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#FF6A6A6A"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="22,18,22,18">
                <Border Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Label Set"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,9,0,0" Text="Alignment Label Set Style" FontSize="14" Foreground="#FF444444" />
                        <ComboBox x:Name="LabelSetComboBox" Grid.Row="0" Grid.Column="2" Height="36" Padding="8,4" FontSize="14"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Alignment Label Set Style" FontWeight="Bold" /><LineBreak />
                                    Conjunto de labels (estacoes, geometria, etc.) aplicado a todos os alinhamentos do desenho. Digite para filtrar a lista de estilos disponiveis.
                                </TextBlock>
                            </ComboBox.ToolTip>
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Margin="0,14,0,0"
                        Background="#FFF0F0F0"
                        BorderBrush="#FFD8D8D8"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock Text="Opcoes"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF555555" />
                </Border>

                <Border Margin="0,14,0,0"
                        Background="White"
                        BorderBrush="#FFE1E1E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18">
                    <StackPanel>
                        <CheckBox x:Name="ApagarExistentesCheckBox"
                                  FontSize="14"
                                  Foreground="#FF444444"
                                  IsChecked="True"
                                  Content="Apagar labels existentes antes de aplicar">
                            <CheckBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="350">
                                    <Run Text="Apagar labels existentes" FontWeight="Bold" /><LineBreak />
                                    Quando marcado, todos os label groups atualmente aplicados aos alinhamentos serao apagados antes da importacao do novo label set. Evita acumulo de labels antigos com os novos. Quando desmarcado, o novo label set e adicionado ao que ja existe.
                                </TextBlock>
                            </CheckBox.ToolTip>
                        </CheckBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border x:Name="StatusBorder"
                Grid.Row="2"
                Visibility="Collapsed"
                BorderThickness="1"
                CornerRadius="0"
                Padding="22,10">
            <TextBlock x:Name="StatusTextBlock"
                       FontSize="13"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Text="O comando aplica o label set a todos os alinhamentos do desenho."
                           FontSize="13"
                           Foreground="#FF666666" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="CancelarButton" Width="110" Height="36" Margin="0,0,10,0" Click="AoClicarCancelar" Content="Fechar" />
                    <Button x:Name="ConfirmarButton" Width="130" Height="36" Click="AoClicarConfirmar" Content="Executar" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
